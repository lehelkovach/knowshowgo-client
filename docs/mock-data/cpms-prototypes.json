          "vendor",
          "amount",
          "currency"
        ],
        "optional_keys": [
          "dueDate",
          "status"
        ],
        "keywords": [
          "invoice",
          "vendor",
          "amount",
          "payable"
        ]
      },
      "metadata": {
        "ksgCategoryPrototypeUuid": "cat:invoice:v1"
      }
    },
    {
      "concept_id": "concept:portal-action@1.0.0",
      "kind": "cpms.concept",
      "features": {
        "required_keys": [
          "tool",
          "payload"
        ],
        "optional_keys": [
          "selector",
          "url"
        ],
        "keywords": [
          "click",
          "open",
          "submit",
          "portal"
        ]
      },
      "metadata": {
        "ksgCategoryPrototypeUuid": "cat:procedure-template:v1"
      }
    }
  ],
  "patternPrototypes": [
    {
      "pattern_id": "pattern:invoice-submit-sequence@1.0.0",
      "kind": "cpms.pattern",
      "slots": [
        {
          "name": "open_portal",
          "expects": "concept:portal-action@1.0.0",
          "constraints": {
            "tool_any_of": [
              "browser.open",
              "browser.goto"
            ]
          }
        },
        {
          "name": "fill_invoice",
          "expects": "concept:portal-action@1.0.0",
          "constraints": {
            "tool_any_of": [
              "browser.fill_form",
              "browser.type"
            ]
          }
        },
        {
          "name": "submit_invoice",
          "expects": "concept:portal-action@1.0.0",
          "constraints": {
            "tool_any_of": [
              "browser.click"
            ],
            "payload_selector_contains": "submit"
          }
        }
      ],
      "relations": [
        {
          "type": "before",
          "from": "open_portal",
          "to": "fill_invoice"
        },
        {
          "type": "before",
          "from": "fill_invoice",
          "to": "submit_invoice"
        }
      ]
    }
  ],
