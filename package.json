{
  "name": "@lehelkovach/knowshowgo-client",
  "version": "0.2.3",
  "description": "JavaScript and Python client SDKs for KnowShowGo semantic memory engine",
  "type": "module",
  "main": "js/index.js",
  "types": "js/client.js",
  "exports": {
    ".": {
      "import": "./js/index.js"
    },
    "./client": {
      "import": "./js/client.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lehelkovach/knowshowgo-client.git"
  },
  "homepage": "https://github.com/lehelkovach/knowshowgo-client",
  "bugs": {
    "url": "https://github.com/lehelkovach/knowshowgo-client/issues"
  },
  "keywords": [
    "semantic-memory",
    "knowledge-graph",
    "ai-agents",
    "hallucination-detection",
    "knowshowgo"
  ],
  "author": "Leh Kovach",
  "license": "MIT",
  "peerDependencies": {
    "knowshowgo": "0.2.3-dev"
  },
  "dependencies": {
    "node-fetch": "^2.6.0"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "esbuild": "^0.17.0"
  },
  "scripts": {
    "test": "node --test js/client.test.mjs",
    "test:integration": "node --test scripts/live-contract-smoke.js",
    "test:integration:live": "node scripts/live-contract-smoke.js",
    "test:coverage": "jest --coverage",
    "build": "esbuild js/index.js --bundle --platform=node --format=esm --outfile=dist/index.js",
    "prepack": "npm run build && npm run test",
    "prepublishOnly": "npm run test && npm run test:integration"
  },
  "files": [
    "js",
    "python",
    "scripts",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
